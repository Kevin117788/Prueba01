@{
    ViewBag.Title = "Login";
}

<div class="login-container">
    <div class="login-box">
        <h2>@ViewBag.Message</h2>

        @using (Html.BeginForm("Login", "Login", FormMethod.Post, new { @class = "login-form" }))
        {
            <div class="form-group">
                <label for="usuario">Usuario:</label>
                <input type="text" id="usuario" name="usuario" class="form-control" placeholder="Ingrese su usuario" required />
            </div>

            <div class="form-group">
                <label for="password">Contrasena:</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Ingrese su contrasena" required />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary btn-block">Iniciar Sesion</button>
            </div>

            <div class="form-footer">
                <a href="#">¿Olvidaste tu contrasena?</a>
                <br />
                <br />
                @Html.ActionLink("¿No tienes un usuario? Regístrate aquí", "Registro", "Login")
            </div>
        }
    </div>
</div>
