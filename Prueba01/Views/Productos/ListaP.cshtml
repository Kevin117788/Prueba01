@model IEnumerable<Prueba01.Models.Producto>
@{
    ViewBag.Title = "Lista de Productos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Agregar Productos</h2>
<form action="/Productos/Agregar" method="post" onsubmit="return validarFormulario()">
    <div class="Fila">
        <div class="Campo">
            <label>ID:</label>
            <input type="text" id="ID" name="ID" maxlength="10" pattern="[0-9]+" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required />
        </div>
        <div class="Campo">
            <label>Nombre:</label>
            <input type="text" id="NombreProducto" name="Nombre" maxlength="50" pattern="[A-Za-z0-9ÁÉÍÓÚáéíóúÑñ ]+" oninput="this.value = this.value.replace(/[^A-Za-z0-9ÁÉÍÓÚáéíóúÑñ ]/g, '')" required />
        </div>
    </div>
    <div class="Fila">
        <div class="Campo">
            <label>Categoría:</label>
            <select id="Categoria" name="Categoria" required>
                <option value="">Seleccione una categoría</option>
                @foreach (var cat in ViewBag.Categorias)
                {
                    <option value="@cat">@cat</option>
                }
            </select>
        </div>
        <div class="Campo">
            <label>Precio:</label>
            <input type="text" id="Precio" name="Precio" pattern="[0-9]+" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required />
        </div>
    </div>
    <div class="Fila">
        <div class="Campo">
            <label>Descripción:</label>
            <input type="text" id="Descripcion" name="Descripcion" maxlength="200" required />
        </div>
    </div>
    <button type="submit">Agregar Producto</button>
</form>

<main aria-labelledby="title">
    <h2 id="title">Lista de Productos Electrónicos</h2>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Categoría</th>
                <th>Descripción</th>
                <th>Precio</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var producto in Model)
                {
                    <tr>
                        <td>@producto.ID</td>
                        <td>@producto.Nombre</td>
                        <td>@producto.Categoria</td>
                        <td>@producto.Descripcion</td>
                        <td>$@producto.Precio</td>
                        <td>
                            <form action="/Productos/Eliminar" method="post" style="display:inline-block;">
                                <input type="hidden" name="id" value="@producto.ID" />
                                <button type="submit" class="btn-eliminar" onclick="return confirm('¿Estás seguro de eliminar este producto?')">
                                    Eliminar
                                </button>
                            </form>
                            <form action="/Carrito/Agregar" method="post" style="display:inline-block; margin-left: 5px;">
                                <input type="hidden" name="id" value="@producto.ID" />
                                <button type="submit" class="btn btn-success">
                                    Agregar al Carrito
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    

</main>

<script>
    function validarFormulario() {
        var precio = document.getElementById("Precio").value;

        // Validar que el precio solo contenga números
        if (!/^\d+$/.test(precio)) {
            alert("El precio debe contener solo números");
            return false;
        }

        // Validar longitud
        if (precio.length > 10) {
            alert("El precio no puede tener más de 10 dígitos");
            return false;
        }

        return true;
    }
</script>