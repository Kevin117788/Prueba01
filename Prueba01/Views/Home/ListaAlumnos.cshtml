@model IEnumerable<Prueba01.Models.Alumno>
@{
    ViewBag.Title = "Lista de Alumnos";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Agregar Alumnos</h2>
<form action="/Home/Agregar" method="post">   
    <div class="Fila">
        <div class="Campo">
            <label>Matricula:</label>
            <input type="text" id="Matricula" name="Matricula" maxlength="15" pattern="[0-9]+" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required />
            <small>Solo números, máximo 15 dígitos</small>
        </div>
    </div>
    <div class="Fila">
        <div class="Campo">
            <label>Nombre:</label>
            <input type="text" id="Nombre" name="Nombre" maxlength="50" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ ]+" oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñ ]/g, '')" required />
            <small>Solo letras, máximo 50 caracteres</small>
        </div>
    </div>
    <div class="Fila">
         <div class="Campo">
             <label>Apellido Paterno:</label>
             <input type="text" id="ApellidoPaterno" name="ApellidoPaterno" maxlength="50" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ ]+" oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñ ]/g, '')" required />
             <small>Solo letras, máximo 50 caracteres</small>
         </div>
    </div>
    <div class="Fila">
         <div class="Campo">
             <label>Apellido Materno:</label>
             <input type="text" id="ApellidoMaterno" name="ApellidoMaterno" maxlength="50" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ ]+" oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñ ]/g, '')" />
             <small>Solo letras, máximo 50 caracteres</small>
         </div>
    </div>
    <div class="Fila">
         <div class="Campo">
             <label>Carrera:</label>
             <input type="text" id="Carrera" name="Carrera" maxlength="100" required />
             <small>Máximo 100 caracteres</small>
         </div>
    </div>
            <button type="submit">Agregar</button>
</form>

<main aria-labelledby="title">
    <h2 id="title">@ViewBag.Title</h2>

    <div style="margin-bottom: 20px;">
        <strong>Carrera:</strong> @ViewBag.Carrera<br />
        <strong>Materia:</strong> @ViewBag.Materia<br />
        <strong>Docente:</strong> @ViewBag.Docente
    </div>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Matrícula</th>
                <th>Nombre</th>
                <th>Apellido paterno</th>
                <th>Apellido materno</th>
                <th>Carrera</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var alumno in Model)
                {
                    <tr>
                        <td>@alumno.Matricula</td>
                        <td>@alumno.Nombre</td>
                        <td>@alumno.ApellidoPaterno</td>
                        <td>@alumno.ApellidoMaterno</td>
                        <td>@alumno.Carrera</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</main>
